msgstr "SAT>IP SSDP MX sekund"

#. help: General - satipClearEpgCache
msgctxt "#30910"
msgid ""
msgstr "Wartość MX używana w żądaniach SSDP M-SEARCH."

#. message: General - satipClearEpgCache
