msgid ""
msgstr "Hneka slóð lógógrunns"

#. notification: General - satipClearEpgCache
msgctxt "#30912"
msgid ""
msgstr "Valfrjáls slóð lógógrunns sem notuð er þegar lógó eru ekki felld inn í spilunarlista/EPG."

#. notification: SAT>IP EPG scan started
msgctxt "#30913"
msgid ""
msgstr "Hreinsaðu SAT>IP EPG skyndiminni"

#. notification: SAT>IP EPG scan finished
msgctxt "#30914"
msgid ""
msgstr "Eyðir skyndiminni SAT>IP EPG gögnum. Fersk gögn hlaðast við næstu Kodi EPG endurnýjun."

#. label: General - satipUseFritzBoxAuth
msgctxt "#30915"
msgid ""
msgstr "Eyða SAT>IP EPG skyndiminni núna?"

#. help: General - satipUseFritzBoxAuth
msgctxt "#30916"
msgid ""
msgstr "SAT>IP EPG skyndiminni hreinsaður. Endurnýjaðu Kodi EPG til að endurhlaða."

#. label: General - satipFritzBoxSid
msgctxt "#30917"
msgid ""
msgstr "Kodi er að endurhlaða SAT>IP EPG gögnum. Þetta gæti tekið nokkurn tíma."

#. help: General - satipFritzBoxSid
msgctxt "#30918"
msgid ""
msgstr "SAT>IP EPG endurhleðslu lokið."

#. label: General - satipFritzBoxPassword
msgctxt "#30919"
msgid ""
msgstr "Notaðu FRITZ!Box innskráningu til að athuga lógó"

#. help: General - satipFritzBoxPassword
msgctxt "#30920"
msgid ""
