      <group id="2" label="30078">
        <setting id="connectioncheckinterval" type="integer" label="30080" help="30629">
          <level>1</level>
          <default>10</default>
          <constraints>
            <minimum>1</minimum>
            <step>1</step>
            <maximum>60</maximum>
          </constraints>
          <control type="slider" format="integer">
            <popup>true</popup>
            <formatlabel>14045</formatlabel>
          </control>
        </setting>
        <setting id="connectionchecktimeout" type="integer" label="30079" help="30628">
          <level>2</level>
          <default>20</default>
          <constraints>
            <minimum>1</minimum>
            <step>1</step>
            <maximum>60</maximum>
          </constraints>
          <control type="slider" format="integer">
            <popup>true</popup>
            <formatlabel>14045</formatlabel>
          </control>
        </setting>
      </group>
      <group id="3" label="30900">
        <setting id="satipSelectServerAction" type="string" label="30925" help="30926">
          <level>1</level>
          <default></default>
          <constraints>
            <allowempty>true</allowempty>
          </constraints>
          <control type="button" format="action">
            <data>RunScript(special://home/addons/pvr.satip/resources/lib/select_satip_server.py)</data>
