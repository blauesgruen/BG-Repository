            <maximum>5</maximum>
          </constraints>
          <control type="slider" format="integer">
            <popup>true</popup>
            <formatlabel>14045</formatlabel>
          </control>
        </setting>
        <setting id="satipLogoBaseUrl" type="string" label="30911" help="30912">
          <level>2</level>
          <default></default>
          <constraints>
            <allowempty>true</allowempty>
          </constraints>
          <control type="edit" format="string" />
        </setting>
      </group>
