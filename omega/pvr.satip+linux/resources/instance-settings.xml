        <setting id="satipPreferFritzHd" type="boolean" label="30905" help="30906">
          <level>0</level>
          <default>true</default>
          <control type="toggle" />
        </setting>
        <setting id="satipDiscoveryTimeoutMs" type="integer" label="30907" help="30908">
          <level>1</level>
          <default>3000</default>
          <constraints>
            <minimum>1000</minimum>
            <step>250</step>
            <maximum>10000</maximum>
          </constraints>
          <control type="slider" format="integer">
            <popup>true</popup>
            <formatlabel>14045</formatlabel>
          </control>
        </setting>
        <setting id="satipDiscoveryMxSeconds" type="integer" label="30909" help="30910">
          <level>1</level>
          <default>2</default>
          <constraints>
            <minimum>1</minimum>
