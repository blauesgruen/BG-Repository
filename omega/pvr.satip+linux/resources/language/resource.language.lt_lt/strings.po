msgid ""
msgstr "Nepaisyti logotipo pagrindinio URL"

#. notification: General - satipClearEpgCache
msgctxt "#30912"
msgid ""
msgstr "Pasirenkamas logotipo bazinis URL, naudojamas, kai logotipai nėra įterpti į grojaraštį / EPG."

#. notification: SAT>IP EPG scan started
msgctxt "#30913"
msgid ""
msgstr "Išvalykite SAT>IP EPG talpyklą"

#. notification: SAT>IP EPG scan finished
msgctxt "#30914"
msgid ""
msgstr "Ištrina talpykloje saugomus SAT>IP EPG duomenis. Nauji duomenys įkeliami kitą „Kodi EPG“ atnaujinimą."

#. label: General - satipUseFritzBoxAuth
msgctxt "#30915"
msgid ""
msgstr "Ištrinti SAT>IP EPG talpyklą dabar?"

#. help: General - satipUseFritzBoxAuth
msgctxt "#30916"
msgid ""
msgstr "SAT>IP EPG talpykla išvalyta. Atnaujinkite Kodi EPG, kad įkeltumėte iš naujo."

#. label: General - satipFritzBoxSid
msgctxt "#30917"
msgid ""
msgstr "Kodi iš naujo įkelia SAT>IP EPG duomenis. Tai gali užtrukti šiek tiek laiko."

#. help: General - satipFritzBoxSid
msgctxt "#30918"
msgid ""
msgstr "SAT>IP EPG perkrovimas baigtas."

#. label: General - satipFritzBoxPassword
msgctxt "#30919"
msgid ""
msgstr "Logotipams tikrinti naudokite FRITZ!Box prisijungimo duomenis"

#. help: General - satipFritzBoxPassword
msgctxt "#30920"
msgid ""
msgstr "Jei įjungta, logotipo URL patikrinimas pagal FRITZ!Box naudoja vietinį prisijungimo seansą."

#. label: General - satipDiscoverSelectServer
msgctxt "#30921"
msgid ""
msgstr "FRITZ!Box vartotojo vardas"

#. help: General - satipDiscoverSelectServer
msgctxt "#30922"
msgid ""
msgstr "Vartotojo vardas, naudojamas vietiniam FRITZ!Box prisijungimui norint pasiekti apsaugotus kanalų logotipus."

#. heading: SAT>IP server select dialog
msgctxt "#30923"
